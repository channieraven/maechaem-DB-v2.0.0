# Supabase — get these from https://app.supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Legacy (Google Apps Script) — no longer required for new deployments
# VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/...

# Public URL of the deployed app (used as the base for magic-link redirects).
# Set this to the production origin so that magic-link emails point to the
# correct host instead of localhost.
# Example: VITE_SITE_URL=https://your-app.example.com
VITE_SITE_URL=

# Server
PORT=8080
NODE_ENV=development
